
(load "../utils/init.repl")

(begin-tx)
(env-data { "init": true })
(env-sigs [ { "key": keys.bridge, "caps": [] } ])
(load "merkle.pact")
(merkle.initialize)
(commit-tx)
(print "Loaded Merkle Tree")


(begin-tx)
(namespace "free")

(merkle.insert-node "rTIotnb3081ChKVEPxfxlis25JGzCkCyQFhJ5Ze6X7U") ;; insert 0xad3228b676f7d3cd4284a5443f17f1962b36e491b30a40b2405849e597ba5fb5

(merkle.insert-node "tMEZUZV8b49kLEr2HNayRkD-xtx_xgfuggapnpJBDTA") ;; insert 0xb4c11951957c6f8f642c4af61cd6b24640fec6dc7fc607ee8206a99e92410d30

(print (merkle.get-tree))
(print (merkle.get-temp))


(print (merkle.root)) ;; outputs 0xe3713ed08fee89e321d79aecae8a306823ab3cdfd48e0c5a5762ed5dceaa4345, expected 0x0xffaea2fed01c40da554a01acafbbbd94f52915b9d56fb2cceb93e0d53454eb02

(commit-tx)
