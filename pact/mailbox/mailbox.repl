;;process
(begin-tx)
(namespace "free")
(use hyperlane-message [hyperlane-message])

(let
    (
        (message:object{hyperlane-message} 
            { 
                "version": 3,
                "nonce": 0,
                "originDomain": 31337,
                "sender": "0x00000000000000000000000032edc4d32327c7f0fa8b63626fe4c9489f4be34a",
                "destinationDomain": 626,
                "recipient": "0x36594b7a7170444e41546d5068554a7a63354131376d4a624658482d64426b56",
                "tokenMessage": 
                {
                    "recipient": "a94c35ab1bd70243ec670495077f7846373b4dc5e9779d7a6732b5ceb6fde059c", 
                    "amount": 599.0,
                    "chainId": 1
                }
            }
        )
        (encoded-token-message:string "")
    )
    (print (mailbox.shallow-process encoded-token-message))
    
    ;  (env-verifiers [{"name": "hyperlane_v3_message", "caps": [ (mailbox.PROCESS-MLC encoded-token-message "ab" ["ab"]) ] }])
