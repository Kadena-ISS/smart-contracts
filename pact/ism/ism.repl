
(load "../utils/init.repl")

(begin-tx)
(env-data { "init": true })
(env-sigs [ { "key": keys.bridge, "caps": [] } ])
(load "ism.pact")
(load "../validator-announce/validator-announce.pact")
(commit-tx)
(print "Loaded ISM")

(begin-tx)
(namespace "free")

(env-sigs [ { "key": keys.bridge, "caps": [ (ism.ONLY_ADMIN) ] } ])

(ism.initialize validator-announce 5)

(commit-tx)
