
(load "../utils/init.repl")

(begin-tx)
(namespace "free")
(use hyperlane-message [hyperlane-message])

(load "mock.pact")

(let
    (
        (encoded-token-message:string "")
    )
    
    ;  (env-verifiers [{"name": "hyperlane_v3_message", "caps": [ (mailbox.PROCESS-MLC encoded-token-message "ab" ["ab"]) ] }])
    ;  (with-applied-env (mailbox.process-mlc encoded-token-message ["ab"] ))
    (print (mailbox.decode-message encoded-token-message))
)

(commit-tx)

