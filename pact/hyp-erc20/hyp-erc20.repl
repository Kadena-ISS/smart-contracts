
(load "../utils/init.repl")

(begin-tx)
(env-data { "init": true })
(env-sigs [ { "key": keys.bridge, "caps": [] } ])
(load "../mailbox/mailbox.pact")
(load "../igp/igp.pact")
(load "hyp-erc20.pact")
(hyp-erc20.initialize igp)

(commit-tx)
(print "Loaded HypERC20")


; enroll-remote-router
(begin-tx)

(let
    (
        (encoded-token-message:string "")
    )
    
    (bind (hyperlane-decode-token-message encoded-token-message)
        {
            "amount" := amount,
            "recipient" := recipient
        }
        ;; a94c35ab1bd70243ec670495077f7846373b4dc5e9779d7a6732b5ceb6fde059c
        (print (format "{} \n{}" [recipient (create-principal recipient)]))
    )
)

(commit-tx)