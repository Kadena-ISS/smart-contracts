(load "../utils/init.repl")

(begin-tx)
(env-data { "init": true })
(env-sigs [ { "key": keys.bridge, "caps": [] } ])
(load "i-practice1.pact")
(load "i-practice2.pact")
(load "practice1.pact")
(load "practice2.pact")

(print "loaded practice1-iface")
(print "loaded practice2-iface")
(print "loaded practice1")
(print "loaded practice2")
(commit-tx)

;; initialize
(begin-tx)
(namespace "free")
(env-sigs [ { "key": keys.bridge, "caps": [ (practice1.ONLY_ADMIN) ] } ])
(practice1.initialize practice2)

(print "initialized practice1")
(commit-tx)



(begin-tx)
(namespace "free")
(env-sigs [ { "key": keys.bridge, "caps": [ (practice2.ONLY_ADMIN) ] } ])
(practice2.initialize practice1)

(print "initialized practice2")
(commit-tx)

;; sucessfull capability
(begin-tx)
(namespace "free")
(practice2.add-balance "alice" { "name": "alice", "amount": 50 })
(practice2.add-balance "bob" { "name": "bob", "amount": 100 })

(print (practice2.get-balance "alice"))
(print (practice2.get-balance "bob"))
(commit-tx)

;; NOTE: This code will never work because the caller is restricted and it's only the owner
;; of our ONLY_PRACTICE2 capability. This capability cannot be acquired by any other account.
 
;; failing capability
(begin-tx)
(namespace "free")
(expect-failure "Cannot interact with practice1 directly" (practice1.add-balance "alice" { "name": "alice", "amount": 190 }))
(expect-failure "Cannot interact with practice1 directly" 
    (practice1.get-balance "alice")
)

(print (practice2.get-balance "alice"))
(print (practice2.get-balance "bob"))
(commit-tx)